APP_NAME="PSHT Jember Portal"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# Logging
LOG_CHANNEL=stack
LOG_STACK=single,kamus_error
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Optional remote sink for kamus_error channel (leave empty to disable)
KAMUS_ERROR_ENDPOINT=
KAMUS_ERROR_TOKEN=

# Database (MySQL)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=psht_jember
DB_USERNAME=root
DB_PASSWORD=

# Session security (UU PDP)
SESSION_DRIVER=database
SESSION_LIFETIME=60
SESSION_EXPIRE_ON_CLOSE=false
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# Authentication
AUTH_GUARD=member
AUTH_MODEL=App\Models\Member

# Admin seed
ADMIN_SEED_EMAIL=admin@psht-jember.local
ADMIN_SEED_PASSWORD=ChangeMe!Now2026

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@psht-jember.local"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Browsershot / Puppeteer (leave empty to use auto-detected paths)
BROWSERSHOT_NODE_BINARY=
BROWSERSHOT_NPM_BINARY=
BROWSERSHOT_CHROME_PATH=
